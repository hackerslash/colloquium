# `pnpm tauri dev` is `pnpm run tauri dev`, and pnpm runs a "verify deps"
# check before every script — which shells out to `pnpm install` and re-runs
# the supply-chain policy, so a machine with a global minimum-release-age
# policy fails the check on every launch (a project .npmrc can't relax a
# security policy — pnpm ignores local attempts to weaken it, by design).
# Turning off the pre-run verification stops `pnpm tauri dev` from triggering
# that reinstall/policy check at all. Deps are still installed explicitly via
# `pnpm install` (see README); this only skips the redundant per-script check.
verify-deps-before-run=false

# Kept for the direct `pnpm install` path on machines without a global
# policy; ignored where a stricter global policy is set.
minimum-release-age=0
