# pnpm's minimum-release-age supply-chain guard blocks installing packages
# published too recently. Our lockfile pins exact, already-vetted versions
# (e.g. tailwindcss 4.3.3) — disable the age check for this project only so
# `pnpm install`/`pnpm tauri dev` don't keep re-failing as those versions age
# in and out of an arbitrary time window on different machines/clocks.
minimum-release-age=0
